# Caddy конфиг для prod.
#
# Делает:
#   - Авто-TLS от Let's Encrypt (нужен порт 80 + правильный DNS-A-запись)
#   - Прокси на app:8000
#   - Basic-auth для /admin/* и /api/v1/admin/* и /docs (Swagger)
#   - Базовые security-headers и gzip

{$DOMAIN} {
    encode gzip

    # Basic-auth для админ-путей и /docs (последний не критично, но
    # лучше не палить контракт API наружу).
    @protected {
        path /admin* /api/v1/admin* /docs /redoc /openapi.json
    }
    basic_auth @protected {
        {$CADDY_ADMIN_USER} {$CADDY_ADMIN_HASH}
    }

    # Всё остальное — публично, проксируется на app.
    reverse_proxy app:8000

    # Защитные заголовки
    header {
        X-Content-Type-Options "nosniff"
        Strict-Transport-Security "max-age=63072000; includeSubDomains"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "SAMEORIGIN"
        # Скрываем версию сервера
        -Server
    }

    log {
        output stdout
        format console
    }
}
