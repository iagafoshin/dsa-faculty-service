# === База ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME             # ← В ПРОДЕ замени на длинный random (32+ символов)
POSTGRES_DB=hse_faculty
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@db:5432/hse_faculty

# === Приложение ===
APP_NAME=dsa-faculty-service
APP_VERSION=0.4.0
ADMIN_TOKEN=changeme                     # ← В ПРОДЕ замени на длинный random
CORS_ORIGINS=*
LOG_LEVEL=INFO

# === Prod-only: Caddy ===
# Домен (без http://) с настроенной A-записью на IP сервера.
DOMAIN=faculty.example.ru
# Логин/bcrypt-хеш для basic-auth на /admin/* и /docs.
# Хеш сгенерировать:
#   docker run --rm caddy:2-alpine caddy hash-password
CADDY_ADMIN_USER=admin
CADDY_ADMIN_HASH=$2a$14$REPLACE_ME_WITH_BCRYPT_HASH
